generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  sku         String   @unique
  barcode     String?  @unique
  basePrice   Decimal  @map("base_price") @db.Decimal(12, 2)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  units        ProductUnit[]
  inventory    Inventory?
  saleItems    SaleItem[]
  movements    InventoryMovement[]
  stockBatches StockBatch[]

  @@map("products")
}

model ProductUnit {
  id               String  @id @default(uuid())
  productId        String  @map("product_id")
  unitName         String  @map("unit_name") // e.g., "piece", "kilo", "meter", "box"
  conversionFactor Decimal @default(1) @map("conversion_factor") @db.Decimal(12, 4) // how many base units in this unit
  price            Decimal @db.Decimal(12, 2)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, unitName])
  @@map("product_units")
}

model Inventory {
  id        String   @id @default(uuid())
  productId String   @unique @map("product_id")
  quantity  Decimal  @default(0) @db.Decimal(12, 4) // base unit quantity
  lowStock  Decimal  @default(10) @map("low_stock") @db.Decimal(12, 4)
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("inventory")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  email     String?
  address   String?
  createdAt DateTime @default(now()) @map("created_at")

  sales Sale[]

  @@map("customers")
}

model Sale {
  id            String   @id @default(uuid())
  receiptNumber String   @unique @map("receipt_number")
  customerId    String?  @map("customer_id")
  subtotal      Decimal  @db.Decimal(12, 2)
  discount      Decimal  @default(0) @db.Decimal(12, 2)
  total         Decimal  @db.Decimal(12, 2)
  paymentMethod String   @default("cash") @map("payment_method")
  amountPaid    Decimal  @default(0) @map("amount_paid") @db.Decimal(12, 2)
  change        Decimal  @default(0) @db.Decimal(12, 2)
  cashier       String?
  terminalId    String?  @map("terminal_id")
  createdAt     DateTime @default(now()) @map("created_at")

  customer Customer?  @relation(fields: [customerId], references: [id])
  items    SaleItem[]

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String  @map("sale_id")
  productId String  @map("product_id")
  unitName  String  @map("unit_name")
  quantity  Decimal @db.Decimal(12, 4)
  price     Decimal @db.Decimal(12, 2)
  costPrice Decimal @default(0) @map("cost_price") @db.Decimal(12, 2)
  discount  Decimal @default(0) @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)

  sale    Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@map("sale_items")
}

model SyncQueue {
  id         String   @id @default(uuid())
  tableName  String   @map("table_name")
  recordId   String   @map("record_id")
  operation  String   // INSERT, UPDATE, DELETE
  payload    Json
  isSynced   Boolean  @default(false) @map("is_synced")
  attempts   Int      @default(0)
  lastError  String?  @map("last_error")
  createdAt  DateTime @default(now()) @map("created_at")
  syncedAt   DateTime? @map("synced_at")

  @@index([isSynced, createdAt])
  @@map("sync_queue")
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String
  name      String
  role      Role     @default(CASHIER)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  CASHIER
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?  @map("user_id")
  userName   String?  @map("user_name")
  action     String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([action, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model InventoryMovement {
  id          String   @id @default(uuid())
  productId   String   @map("product_id")
  type        String
  quantity    Decimal  @db.Decimal(12, 4)
  previousQty Decimal  @map("previous_qty") @db.Decimal(12, 4)
  newQty      Decimal  @map("new_qty") @db.Decimal(12, 4)
  reason      String?
  referenceId String?  @map("reference_id")
  userId      String?  @map("user_id")
  userName    String?  @map("user_name")
  createdAt   DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, createdAt])
  @@map("inventory_movements")
}

model StockBatch {
  id         String   @id @default(uuid())
  productId  String   @map("product_id")
  quantity   Decimal  @db.Decimal(12, 4)
  initialQty Decimal  @map("initial_qty") @db.Decimal(12, 4)
  costPrice  Decimal  @map("cost_price") @db.Decimal(12, 2)
  reference  String?
  receivedAt DateTime @default(now()) @map("received_at")
  userId     String?  @map("user_id")
  userName   String?  @map("user_name")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, receivedAt])
  @@map("stock_batches")
}
